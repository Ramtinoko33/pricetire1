# ============================================================
# .env.example — Copia para .env e preenche os valores
# Estas variáveis são configuradas no Railway (Settings > Variables)
# ============================================================

# --- MongoDB Atlas ---
# Obtém em: https://cloud.mongodb.com → Connect → Drivers
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=pneu_price_scout

# --- CORS ---
# URL do teu frontend Vercel (ex: https://pricetire1.vercel.app)
# Separa múltiplos com vírgula
CORS_ORIGINS=https://pricetire1.vercel.app,http://localhost:3000

# --- Playwright ---
# Já definido no Dockerfile — não é necessário alterar
PLAYWRIGHT_BROWSERS_PATH=/pw-browsers
