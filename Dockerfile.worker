FROM mcr.microsoft.com/playwright/python:v1.58.0-jammy

WORKDIR /app

COPY requirements.worker.txt .
RUN pip install --no-cache-dir -r requirements.worker.txt

ENV PLAYWRIGHT_BROWSERS_PATH=/pw-browsers
# A imagem base já tem todas as dependências de sistema — sem --with-deps
RUN playwright install chromium

COPY backend/worker.py ./backend/worker.py
COPY backend/run_scraper.py ./backend/run_scraper.py

RUN mkdir -p /app/tmp/scraper_results

CMD ["python3", "backend/worker.py"]
